#!/usr/bin/env sh

echo ""
echo "\033[1m🔍 Pre-push: Lighthouse 质量门禁\033[0m"
echo ""

# Cleanup helper — kill server if we started it
kill_server() {
  if [ "$SERVER_STARTED" = true ] && [ -n "$SERVER_PID" ]; then
    kill $SERVER_PID 2>/dev/null
    wait $SERVER_PID 2>/dev/null || true
  fi
}

# Step 1: Build
echo "📦 构建中..."
npm run build || {
  echo "\033[31m✗ 构建失败，push 已阻止。\033[0m"
  exit 1
}
echo ""

# Step 2: Dev server — detect or start
SERVER_STARTED=false
if curl -s -o /dev/null http://localhost:5500 2>/dev/null; then
  echo "🔗 检测到 localhost:5500 已在运行，复用现有服务。"
else
  echo "🚀 启动本地服务器 (localhost:5500)..."
  python3 -m http.server 5500 -d . > /dev/null 2>&1 &
  SERVER_PID=$!
  SERVER_STARTED=true

  # Wait for server to be ready (max ~10s)
  RETRIES=0
  while ! curl -s -o /dev/null http://localhost:5500 2>/dev/null; do
    RETRIES=$((RETRIES + 1))
    if [ "$RETRIES" -ge 20 ]; then
      echo "\033[31m✗ 服务器启动超时，push 已阻止。\033[0m"
      kill_server
      exit 1
    fi
    sleep 0.5
  done
  echo "✓ 服务器已就绪。"
fi
echo ""

# Step 3: Run Lighthouse sequentially
echo "🔍 运行 Lighthouse 审计 (H5 → PC 串行)..."
echo ""
echo "  📱 H5 (移动端)..."
npm run lh:h5 > /dev/null 2>&1 || {
  echo "\033[31m✗ H5 Lighthouse 审计执行失败，push 已阻止。\033[0m"
  kill_server
  exit 1
}
echo "  ✓ H5 完成"
echo "  🖥  PC (桌面端)..."
npm run lh:pc > /dev/null 2>&1 || {
  echo "\033[31m✗ PC Lighthouse 审计执行失败，push 已阻止。\033[0m"
  kill_server
  exit 1
}

# Step 4: Check scores
node scripts/check-scores.mjs
EXIT_CODE=$?

# Cleanup server
kill_server

exit $EXIT_CODE
